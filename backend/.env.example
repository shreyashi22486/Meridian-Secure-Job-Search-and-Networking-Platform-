# Database
DATABASE_URL=postgresql://user:password@localhost:5432/secure_job_portal

# JWT
JWT_SECRET=generate-a-long-random-string-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# Encryption keys (Generate using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOTP_ENCRYPTION_KEY=your-totp-encryption-key-here
FILE_ENCRYPTION_KEY=your-file-encryption-key-here
FERNET_KEY=your-fernet-key-here

# File uploads
UPLOAD_DIR=./data/resumes
MAX_UPLOAD_SIZE=2097152

# PKI
PKI_KEY_DIR=./data/pki

# CORS
CORS_ORIGINS=http://localhost:5173

# App
APP_NAME=Secure Job Portal
DEBUG=true
