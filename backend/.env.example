# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/secure_job_portal

# JWT
JWT_SECRET=CHANGE-ME-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# Encryption keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOTP_ENCRYPTION_KEY=CHANGE-ME
FILE_ENCRYPTION_KEY=CHANGE-ME

# File uploads
UPLOAD_DIR=./data/resumes
MAX_UPLOAD_SIZE=2097152

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# App
APP_NAME=Secure Job Portal
DEBUG=false
