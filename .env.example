# ─────────────────────────────────────────────────────────────────────────
# Secure Job Portal — Root Environment Variables
# Copy this file to .env and fill in real values
# Usage: docker compose --env-file .env up --build
# ─────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=secure_job_portal

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE-ME-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# ── Encryption Keys (Fernet) ────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=CHANGE-ME
FILE_ENCRYPTION_KEY=CHANGE-ME
FERNET_KEY=CHANGE-ME

# ── File Uploads ─────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=2097152

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-domain.com,http://localhost

# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=Secure Job Portal
DEBUG=false
